# ============================================================================
# EMAIL & ALERT CONFIGURATION
# ============================================================================

# Gmail Account for Sending Alerts
# IMPORTANT: Use an App-Specific Password, not your regular Gmail password
# Get it from: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# Email Address to Receive Alerts (who gets notified)
ALERT_EMAIL_RECIPIENT=admin@yourdomain.com

# ============================================================================
# ALERT THRESHOLDS (adjust based on your building specifications)
# ============================================================================

# Energy Overuse Threshold in Kilowatts (kW)
# Alert triggered when real_power exceeds this value
ENERGY_OVERUSE_THRESHOLD=5

# Power Spike Threshold in Percentage (%)
# Alert triggered when power increases more than this percentage
POWER_SPIKE_THRESHOLD=50

# Night Usage Threshold in Kilowatts (kW)
# Alert triggered if power exceeds this during night hours (12 AM - 5 AM)
NIGHT_USAGE_THRESHOLD=1

# Voltage Drop Threshold in Volts (V)
# Alert triggered when voltage falls below this value (minimum 210V recommended)
VOLTAGE_DROP_THRESHOLD=210

# ============================================================================
# EXISTING CONFIGURATION (Keep your existing env variables)
# ============================================================================

MONGO_URI=mongodb+srv://your-user:your-pass@your-cluster.mongodb.net/your-db
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-key
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_CLIENT_EMAIL=your-firebase-email
FIREBASE_PRIVATE_KEY=your-firebase-key
HARDWARE_API_KEY=your-hardware-api-key
FRONTEND_URL=http://localhost:3000
MQTT_BROKER_URL=mqtt://your-broker:1883
MQTT_USERNAME=your-mqtt-user
MQTT_PASSWORD=your-mqtt-pass
NODE_ENV=development
