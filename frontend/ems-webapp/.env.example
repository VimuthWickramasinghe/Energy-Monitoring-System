# ============================================================================
# FIREBASE CLIENT-SIDE CONFIGURATION
# These are public keys and are safe to expose on the client.
# ============================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=your_public_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ============================================================================
# SUPABASE CLIENT-SIDE CONFIGURATION
# These are public keys and are safe to expose on the client.
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-key

# ============================================================================
# BACKEND URL
# This is the URL for the frontend to communicate with the backend.
# In the docker-compose setup, this is overridden, but it's good to have here
# for local development outside of Docker.
# ============================================================================
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
